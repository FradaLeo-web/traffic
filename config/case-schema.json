{
  "version": "1.0.0",
  "description": "统一案件档案数据结构，支持跨技能数据共享",
  "case_schema": {
    "case_id": {
      "type": "string",
      "description": "案件唯一ID，自动生成",
      "required": true
    },
    "case_name": {
      "type": "string",
      "description": "案件名称，如：张三与李四民间借贷纠纷案",
      "required": true
    },
    "case_type": {
      "type": "string",
      "enum": ["民事", "刑事", "行政", "仲裁", "执行"],
      "description": "案件类型",
      "required": true
    },
    "case_cause": {
      "type": "string",
      "description": "案由，如：民间借贷纠纷、故意伤害罪等",
      "required": false
    },
    "court": {
      "type": "string",
      "description": "受理法院/仲裁委",
      "required": false
    },
    "case_number": {
      "type": "string",
      "description": "案号",
      "required": false
    },
    "parties": {
      "type": "array",
      "description": "案件当事人信息",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "当事人姓名/名称"},
          "role": {"type": "string", "enum": ["原告", "被告", "上诉人", "被上诉人", "申请人", "被申请人", "第三人", "被害人", "犯罪嫌疑人/被告人"], "description": "当事人角色"},
          "type": {"type": "string", "enum": ["自然人", "法人", "其他组织"], "description": "当事人类型"},
          "id_card": {"type": "string", "description": "身份证号/统一社会信用代码"},
          "contact": {"type": "string", "description": "联系方式"},
          "address": {"type": "string", "description": "住址/住所地"}
        },
        "required": ["name", "role", "type"]
      },
      "required": true
    },
    "lawyer_role": {
      "type": "string",
      "enum": ["原告代理律师", "被告代理律师", "上诉人代理律师", "被上诉人代理律师", "辩护人", "被害人代理人", "第三人代理人"],
      "description": "律师在本案中的代理角色",
      "required": true
    },
    "case_stage": {
      "type": "string",
      "enum": ["立案前", "一审", "二审", "再审", "执行", "仲裁", "调解", "结案"],
      "description": "案件当前阶段",
      "required": true
    },
    "filing_date": {
      "type": "string",
      "format": "date",
      "description": "立案日期",
      "required": false
    },
    "court_session_date": {
      "type": "string",
      "format": "date",
      "description": "开庭日期",
      "required": false
    },
    "judgment_date": {
      "type": "string",
      "format": "date",
      "description": "判决日期",
      "required": false
    },
    "claim_amount": {
      "type": "number",
      "description": "诉讼请求金额/涉案金额",
      "required": false
    },
    "core_controversy": {
      "type": "string",
      "description": "核心争议焦点",
      "required": false
    },
    "key_facts": {
      "type": "string",
      "description": "案件关键事实",
      "required": false
    },
    "evidence_list": {
      "type": "array",
      "description": "证据清单",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "证据名称"},
          "type": {"type": "string", "description": "证据类型"},
          "source": {"type": "string", "description": "证据来源"},
          "content": {"type": "string", "description": "证据主要内容"},
          "proof_object": {"type": "string", "description": "证明对象"},
          "authenticity": {"type": "string", "enum": ["确认", "不确认", "待核实"], "description": "真实性判断"},
          "legitimacy": {"type": "string", "enum": ["确认", "不确认", "待核实"], "description": "合法性判断"},
          "relevance": {"type": "string", "enum": ["确认", "不确认", "待核实"], "description": "关联性判断"},
          "score": {"type": "number", "minimum": 0, "maximum": 100, "description": "证据综合评分"}
        }
      },
      "required": false
    },
    "time_limit_list": {
      "type": "array",
      "description": "案件时限列表",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "时限名称"},
          "deadline": {"type": "string", "format": "date", "description": "截止日期"},
          "status": {"type": "string", "enum": ["待办", "已完成", "逾期"], "description": "状态"},
          "remind": {"type": "boolean", "description": "是否提醒"}
        }
      },
      "required": false
    },
    "document_list": {
      "type": "array",
      "description": "法律文书列表",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "文书名称"},
          "type": {"type": "string", "description": "文书类型"},
          "create_date": {"type": "string", "format": "date", "description": "创建日期"},
          "path": {"type": "string", "description": "文件路径"},
          "status": {"type": "string", "enum": ["草稿", "已完成", "已提交", "已生效"], "description": "状态"}
        }
      },
      "required": false
    },
    "operation_records": {
      "type": "array",
      "description": "操作记录",
      "items": {
        "type": "object",
        "properties": {
          "time": {"type": "string", "format": "datetime", "description": "操作时间"},
          "skill": {"type": "string", "description": "使用的技能"},
          "content": {"type": "string", "description": "操作内容"},
          "result": {"type": "string", "description": "操作结果"}
        }
      },
      "required": false
    },
    "region": {
      "type": "string",
      "description": "案件所在省市编码",
      "required": false
    },
    "tags": {
      "type": "array",
      "description": "案件标签",
      "items": {"type": "string"},
      "required": false
    },
    "notes": {
      "type": "string",
      "description": "备注信息",
      "required": false
    }
  },
  "storage_path": "../workspace/cases/",
  "auto_sync": true,
  "description": "所有技能均可读写该统一结构的案件数据，实现跨技能数据互通，无需用户重复输入"
}
